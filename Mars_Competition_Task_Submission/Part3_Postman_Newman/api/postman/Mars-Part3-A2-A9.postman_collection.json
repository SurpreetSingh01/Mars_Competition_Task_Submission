{
  "info": {
    "_postman_id": "a8fba4e0-0f37-4e86-a71f-83f24e940001",
    "name": "Mars Part3 API Testing (A2-A9)",
    "description": "Submission-ready API suite for Project Mars Part 3. Update endpoint paths in environment if local service routes differ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.variables.set('runTs', new Date().toISOString());",
          "if (!pm.environment.get('authToken')) { pm.environment.set('authToken', ''); }"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time under configured timeout', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(parseInt(pm.environment.get('requestTimeoutMs') || '15000', 10));",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "A2-A9 Happy Path",
      "item": [
        {
          "name": "A2 - Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{authBaseUrl}}{{loginPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A2 status is 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "const token = (json.token && (json.token.token || json.token)) || json.bearerToken || (json.result && json.result.token) || '';",
                  "pm.test('A2 token extracted', function () { pm.expect(token, 'token missing in login response').to.not.equal(''); });",
                  "pm.environment.set('authToken', token);",
                  "const schema = { type: 'object' };",
                  "pm.test('A2 response body is JSON object', function () { pm.expect(json).to.be.an('object'); pm.expect(json).to.have.jsonSchema(schema); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A3 - Is User Authenticated",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{profileBaseUrl}}{{isAuthenticatedPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A3 status is 200/204', function () { pm.expect(pm.response.code).to.be.oneOf([200, 204]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A4 - Add Education",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"{{educationCountry}}\",\n  \"instituteName\": \"{{educationInstitute}}\",\n  \"title\": \"{{educationTitle}}\",\n  \"degree\": \"{{educationDegree}}\",\n  \"yearOfGraduation\": \"{{educationYear}}\"\n}"
            },
            "url": "{{profileBaseUrl}}{{addEducationPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A4 status is 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A5 - Add Certification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"certificationName\": \"{{certificateName}}\",\n  \"certificationFrom\": \"{{certificateFrom}}\",\n  \"certificationYear\": \"{{certificateYear}}\"\n}"
            },
            "url": "{{profileBaseUrl}}{{addCertificationPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A5 status is 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A6 - Get Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{listingBaseUrl}}{{getCategoriesPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A6 status is 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('A6 body is object/array', function () { pm.expect(['object', 'array']).to.include(typeof json); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A7 - Add Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{listingTitle}}_{{$timestamp}}\",\n  \"description\": \"{{listingDescription}}\",\n  \"category\": \"{{categoryName}}\",\n  \"subcategory\": \"{{subcategoryName}}\",\n  \"serviceType\": \"Hourly\",\n  \"locationType\": \"Online\",\n  \"skillTradeType\": \"Credit\",\n  \"credit\": \"{{creditAmount}}\"\n}"
            },
            "url": "{{listingBaseUrl}}{{addListingPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A7 status is 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "const listingId = json.id || json.listingId || (json.result && (json.result.id || json.result.listingId)) || '';",
                  "if (listingId) { pm.environment.set('createdListingId', String(listingId)); }",
                  "pm.test('A7 listing id captured when available', function () { pm.expect(true).to.equal(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A8 - Search Listings",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"terms\": {\n    \"searchString\": \"{{searchTerm}}\"\n  },\n  \"sortPagination\": {\n    \"offset\": 0,\n    \"limit\": 10\n  }\n}"
            },
            "url": "{{listingBaseUrl}}{{searchListingsPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A8 status is 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('A8 response is object/array', function () { pm.expect(['object', 'array']).to.include(typeof json); });"
                ]
              }
            }
          ]
        },
        {
          "name": "A9 - Delete Created Listing (Destructive)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{listingBaseUrl}}{{deleteListingPathTemplate}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const id = pm.environment.get('createdListingId') || pm.environment.get('listingId');",
                  "pm.environment.set('listingId', id);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('A9 status is 200/204/404', function () { pm.expect(pm.response.code).to.be.oneOf([200, 204, 404]); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Negative Cases",
      "item": [
        {
          "name": "N1 - Login with invalid credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{invalidEmail}}\",\n  \"password\": \"{{invalidPassword}}\"\n}"
            },
            "url": "{{authBaseUrl}}{{loginPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('N1 status is 200/400/401', function () { pm.expect(pm.response.code).to.be.oneOf([200, 400, 401]); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('N1 login rejected by API contract', function () {",
                  "  const failed = (json.isSuccess === false) || (json.success === false) || (json.token == null);",
                  "  pm.expect(failed).to.equal(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "N2 - Add Education without auth token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"India\",\n  \"instituteName\": \"No Auth Univ\",\n  \"title\": \"B.Tech\",\n  \"degree\": \"IT\",\n  \"yearOfGraduation\": \"2020\"\n}"
            },
            "url": "{{profileBaseUrl}}{{addEducationPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('N2 status is 401/403', function () { pm.expect(pm.response.code).to.be.oneOf([401, 403]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "N3 - Add Listing invalid payload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"invalid negative case\",\n  \"description\": \"invalid negative case\",\n  \"category\": \"Programming & Tech\",\n  \"subcategory\": \"QA\",\n  \"serviceType\": \"INVALID\",\n  \"locationType\": \"Online\",\n  \"skillTradeType\": \"Credit\",\n  \"credit\": 50\n}"
            },
            "url": "{{listingBaseUrl}}{{addListingPath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('N3 status is 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('N3 invalid payload rejected by API contract', function () {",
                  "  const failed = (json.success === false) || (json.isSuccess === false);",
                  "  pm.expect(failed).to.equal(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Destructive & Cleanup",
      "item": [
        {
          "name": "D1 - Delete listing with invalid id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{listingBaseUrl}}/listing/listing/deleteListing/-999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('D1 status is 400/404', function () { pm.expect(pm.response.code).to.be.oneOf([400, 404]); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "notes", "value": "If your service host/ports differ per API family, split base URL into auth/profile/listing variables in environment." }
  ]
}
