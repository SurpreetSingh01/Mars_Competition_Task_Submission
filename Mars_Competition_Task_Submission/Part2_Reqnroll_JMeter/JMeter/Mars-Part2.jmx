<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Mars Part 2 Test Plan" enabled="true">
      <stringProp name="TestPlan.comments">Single maintainable end-to-end performance plan for Mars Part 2. Verify final payload fields/ports from DevTools before graded submission run.</stringProp>
