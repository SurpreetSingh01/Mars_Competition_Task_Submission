{
  "Application": {
    "BaseUrl": "http://localhost:5003"
  },
  "Browser": {
    "Name": "chrome",
    "Headless": false,
    "Maximize": true
  },
  "Timeouts": {
    "DefaultWaitSeconds": 15,
    "PageLoadSeconds": 60,
    "ScriptSeconds": 30
  },
  "Artifacts": {
    "ScreenshotDirectory": "Artifacts/Screenshots",
    "LogDirectory": "Artifacts/Logs"
  },
  "Authentication": {
    "CredentialsFile": "TestData/credentials.json"
  },
  "Routes": {
    "Profile": "/Account/Profile",
    "ShareSkill": "/Home/ServiceListing",
    "SearchSkill": "/Home/Search",
    "ListingManagement": "/Home/ListingManagement"
  }
}
